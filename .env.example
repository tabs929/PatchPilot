# Copy to .env and fill in. .env is gitignored.

# Required for Phase 1 (oracle baseline) and beyond.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown in src/patchpilot/config.py).
# Confirm the exact model slugs against the current Anthropic model list.
# PATCHPILOT_ITERATION_MODEL=claude-haiku-4-5
# PATCHPILOT_FINAL_MODEL=claude-sonnet-4-5
# PATCHPILOT_MODEL=claude-haiku-4-5

# Dataset selection.
# PATCHPILOT_DATASET=princeton-nlp/SWE-bench_Lite
# PATCHPILOT_SPLIT=test

# Name written into predictions (model_name_or_path) and used to locate harness logs.
# PATCHPILOT_MODEL_NAME=patchpilot-oracle

# Apple Silicon: keep empty string so the harness builds images locally.
# PATCHPILOT_NAMESPACE=
